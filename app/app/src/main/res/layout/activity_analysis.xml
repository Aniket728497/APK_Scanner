<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- App Name -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <!-- Package Name -->
        <TextView
            android:id="@+id/tvPackageName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginBottom="16dp"/>

        <!-- Verdict Banner -->
        <TextView
            android:id="@+id/tvVerdict"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:background="#1E1E1E"/>

        <!-- Risk Score -->
        <TextView
            android:id="@+id/tvScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Section: Install Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📦 Install Info"
            android:textSize="14sp"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvInstallInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#CCCCCC"
            android:background="#1E1E1E"
            android:padding="10dp"
            android:layout_marginBottom="16dp"/>

        <!-- Section: Permissions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔐 Dangerous Permissions"
            android:textSize="14sp"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvPermissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#CCCCCC"
            android:background="#1E1E1E"
            android:padding="10dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="monospace"/>

        <!-- Section: Flagged Combos -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ Flagged Combinations"
            android:textSize="14sp"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvCombos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#CCCCCC"
            android:background="#1E1E1E"
            android:padding="10dp"
            android:layout_marginBottom="16dp"/>

        <!-- Section: Signature -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔏 Signature"
            android:textSize="14sp"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvSignature"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#CCCCCC"
            android:background="#1E1E1E"
            android:padding="10dp"
            android:layout_marginBottom="16dp"/>

        <!-- Section: Community -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌐 Community Analysis"
            android:textSize="14sp"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvCommunity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#CCCCCC"
            android:background="#1E1E1E"
            android:padding="10dp"
            android:layout_marginBottom="16dp"/>

        <!-- Section: Package Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏷️ Package Name Check"
            android:textSize="14sp"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvPackageCheck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#CCCCCC"
            android:background="#1E1E1E"
            android:padding="10dp"
            android:layout_marginBottom="24dp"/>

        <!-- Uninstall Button -->
        <Button
            android:id="@+id/btnUninstall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🗑️ Uninstall App"
            android:backgroundTint="#CC2222"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>